{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/relay/**",
              "ui_kits/dashboard/**",
              "ui_kits/site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|Hanken Grotesk|Space Grotesk))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, Hanken Grotesk, Space Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|mono|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, mono, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:relay|provider|tool|gold|local|neutral|info|warning|critical|success)$/]",
        "message": "<Badge> tone must be one of 'relay' | 'provider' | 'tool' | 'gold' | 'local' | 'neutral' | 'info' | 'warning' | 'critical' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|iconLeft|iconRight|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, iconLeft, iconRight, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|provider|tool|secondary|ghost|gold|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'provider' | 'tool' | 'secondary' | 'ghost' | 'gold' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|glow|accent|padded|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, glow, accent, padded, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='glow'] > Literal[value!=/^(?:relay|gold|provider)$/]",
        "message": "<Card> glow must be one of 'relay' | 'gold' | 'provider'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:relay|provider|tool|gold)$/]",
        "message": "<Card> accent must be one of 'relay' | 'provider' | 'tool' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|onChange|placeholder|mono|accent|iconLeft|affix|disabled|type|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, defaultValue, onChange, placeholder, mono, accent, iconLeft, affix, disabled, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:relay|provider|tool)$/]",
        "message": "<Input> accent must be one of 'relay' | 'provider' | 'tool'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|family|format|context|cost|backend|favorite|onToggleFavorite|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ModelRow> doesn't accept that prop. Declared props: id, family, format, context, cost, backend, favorite, onToggleFavorite, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelRow'] > JSXAttribute[name.name='format'] > Literal[value!=/^(?:native|translated|unsupported)$/]",
        "message": "<ModelRow> format must be one of 'native' | 'translated' | 'unsupported'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProviderCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|monogram|brandColor|status|models|note|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ProviderCard> doesn't accept that prop. Declared props: name, monogram, brandColor, status, models, note, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProviderCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:connected|missing|oauth|local)$/]",
        "message": "<ProviderCard> status must be one of 'connected' | 'missing' | 'oauth' | 'local'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RelayMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|variant|title|style|key|ref|className|style|children)$/]",
        "message": "<RelayMark> doesn't accept that prop. Declared props: size, variant, title, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RelayMark'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gradient|mono)$/]",
        "message": "<RelayMark> variant must be one of 'gradient' | 'mono'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RouteEndpoint'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|id|monogram|sub|key|ref|className|style|children)$/]",
        "message": "<RouteEndpoint> doesn't accept that prop. Declared props: name, id, monogram, sub."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
